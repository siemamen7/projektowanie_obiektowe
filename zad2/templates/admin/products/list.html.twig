<!DOCTYPE html>
<html>
<head>
    <title>Manage Products</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="container">
        <h1>Manage Products</h1>
        <p><a href="{{ path('app_admin') }}" class="admin-link">Back to Admin</a></p>
        <p><a href="{{ path('admin_product_new') }}" class="btn-primary">Add New Product</a></p>
        
        {% if products %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Category</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in products %}
                <tr>
                    <td>{{ product.id }}</td>
                    <td>{{ product.name }}</td>
                    <td>${{ product.price }}</td>
                    <td>{{ product.category ? product.category.name : 'None' }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_product_edit', {id: product.id}) }}" class="btn-secondary">Edit</a>
                        <form method="POST" action="{{ path('admin_product_delete', {id: product.id}) }}" style="display: inline;">
                            <button type="submit" class="btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p>No products found.</p>
        {% endif %}
    </div>
</body>
</html>