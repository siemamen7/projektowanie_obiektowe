<!DOCTYPE html>
<html>
<head>
    <title>Manage Orders</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="container">
        <h1>Manage Orders</h1>
        <p><a href="{{ path('app_admin') }}" class="admin-link">Back to Admin</a></p>
        <p><a href="{{ path('admin_order_new') }}" class="btn-primary">Add New Order</a></p>
        
        {% if orders %}
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for order in orders %}
                <tr>
                    <td>{{ order.id }}</td>
                    <td>{{ order.date|date('Y-m-d H:i:s') }}</td>
                    <td>${{ order.total }}</td>
                    <td>{{ order.products|length }}</td>
                    <td class="actions">
                        <a href="{{ path('admin_order_edit', {id: order.id}) }}" class="btn-secondary">Edit</a>
                        <form method="POST" action="{{ path('admin_order_delete', {id: order.id}) }}" style="display: inline;">
                            <button type="submit" class="btn-danger" onclick="return confirm('Are you sure?')">Delete</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p>No orders found.</p>
        {% endif %}
    </div>
</body>
</html>